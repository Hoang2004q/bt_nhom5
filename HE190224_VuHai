import java.util.Random;

public class RPGStatGenerator {
    public static void main(String[] args) {
        Random rand = new Random();
        
        System.out.println("--- Character Stat Roll ---");
        
        // Generate random stats
        int hp = rand.nextInt(50) + 50;      // Random HP between 50-100
        int mana = rand.nextInt(30) + 20;    // Random Mana between 20-50
        int strength = rand.nextInt(15) + 5; // Random STR between 5-20
        
        System.out.println("HP: " + hp);
        System.out.println("Mana: " + mana);
        System.out.println("Strength: " + strength);
        
        System.out.println("\nStats generated successfully! File added to the team repository.");
    }
}
